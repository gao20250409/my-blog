      <h3>DataFrame 构建方式</h3>

      <pre class="code-block"># 方式一：字典列表（List of Dictionaries）
df1 = pd.DataFrame([
    &#123;'姓名': '张三', '语文': 85, '数学': 92, '英语': 78&#125;,
    &#123;'姓名': '李四', '语文': 78, '数学': 88, '英语': 95&#125;,
    &#123;'姓名': '王五', '语文': 92, '数学': 96, '英语': 89&#125;
])

# 方式二：字典，值为列表（Dictionary of Lists）
df2 = pd.DataFrame(&#123;
    '姓名': ['张三', '李四', '王五'],
    '语文': [85, 78, 92],
    '数学': [92, 88, 96],
    '英语': [78, 95, 89]
&#125;)

# 方式三：元组列表 + 指定列名
df3 = pd.DataFrame([
    ('张三', 85, 92, 78),
    ('李四', 78, 88, 95),
    ('王五', 92, 96, 89)
], columns=['姓名', '语文', '数学', '英语'])

# 方式四：列表的列表 + 指定列名和索引
df4 = pd.DataFrame([
    ['张三', 85, 92, 78],
    ['李四', 78, 88, 95],
    ['王五', 92, 96, 89]
], columns=['姓名', '语文', '数学', '英语'], index=['a', 'b', 'c'])</pre>

