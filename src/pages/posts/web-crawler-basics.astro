def save_data(detail_data_list):
    with open("csv_data/top_movies.csv", "w", encoding="utf-8", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=[
            "电影名","年份","类型","上映时间","时长","评分","语言","作者","主演","slogan","简介"
        ])
        writer.writeheader()
        writer.writerows(detail_data_list)

# 主函数
def main():
    detail_data_list = []

    for page_num in range(1, 6):
        # 1.发送请求，获取高分列表
        if page_num == 1:
            top_res = requests.get(TMDB_TOP_URL1, timeout=60)
        else:
            # 获取更多数据（POST翻页）
            top_res = requests.post(TMDB_TOP_URL2, f"page=&#123;page_num&#125;&amp;sort_by=vote_average.desc&amp;vote_count.gte=300", timeout=60)

        # 2.解析数据，获取高分列表
        top_list = html.fromstring(top_res.text).xpath(
            f'//div[@id="page_&#123;page_num&#125;"]//div[@class="relative w-full"]/a/@href'
        )

        # 3.遍历高分列表，获取每部电影的详细信息
        for url in top_list:
            detail_url = TMDB_BASE_URL + url
            detail_data_list.append(get_movie_info(detail_url))

    # 4.存储数据到CSV
    save_data(detail_data_list)

if __name__ == '__main__':
    main()</pre>

