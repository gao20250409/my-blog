    times = detail_txt.xpath('//*[@id="original_header"]/div[2]/section/div[1]/div/span[@class="runtime"]/text()')
    score = detail_txt.xpath('//*[@id="consensus_pill"]/div/div[1]/div/div/@data-percent')
    language = detail_txt.xpath('//*[@id="media_v4"]/div/div/div[2]/div/section/div[1]/div/section[1]/p[3]/text()')
    author = detail_txt.xpath('//*[@id="original_header"]/div[2]/section/div[3]/ol/li[1]/p[1]/a/text()')
