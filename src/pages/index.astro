  </head>
  <body>
    <div class="container">
      <h1>前端开发</h1>
      <div class="nav-links">
        <a href="#">最新文章</a>
        <a href={`${import.meta.env.BASE_URL}about`}>关于我</a>
        <a href="https://github.com/gao20250409/my-blog">GitHub 源码</a>
      </div>

      <!-- 搜索功能 -->
      <div class="search-container">
        <input 
          type="text" 
          id="searchInput" 
          class="search-box" 
          placeholder="🔍 搜索文章标题、描述或标签..."
          autocomplete="off"
        >
        <div id="searchStats" class="search-stats"></div>
      </div>

      <!-- 文章列表 -->
      <div class="posts-section">
        <h2>📝 最新文章</h2>
        <div id="noResults" class="no-results" style="display: none;">
          <h3>😔 没有找到相关文章</h3>
          <p>试试其他关键词，或者浏览所有文章</p>
        </div>
        {
          posts.map((post) => (
            <article class="post-card">
              <h3 class="post-title">
                <a href={post.url}>{post.title}</a>
              </h3>
              <div class="post-meta">📅 发布于 {post.date}</div>
              <p class="post-description">{post.description}</p>
              <div class="post-tags">
                {post.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <script define:vars={{ posts }}>
      // 搜索功能实现
      const searchInput = document.getElementById('searchInput');
      const searchStats = document.getElementById('searchStats');
      const noResults = document.getElementById('noResults');
      const postCards = document.querySelectorAll('.post-card');
      
      // 搜索功能的文章数据类型定义
      const searchPosts = posts.map(post => ({
        ...post,
        element: null
      }));
      
      // 初始化：将DOM元素与数据关联
      postCards.forEach((card, index) => {
        searchPosts[index].element = card;
      });
      
      // 高亮搜索关键词
      function highlightText(text, searchTerm) {
        if (!searchTerm) return text;
        const regex = new RegExp(`(${searchTerm})`, 'gi');
        return text.replace(regex, '<span class="highlight">$1</span>');
      }
      
      // 移除高亮
      function removeHighlight(element) {
        const highlighted = element.querySelectorAll('.highlight');
        highlighted.forEach((span) => {
          span.outerHTML = span.innerHTML;
        });
      }
      
      // 搜索函数
      function performSearch(searchTerm) {
        const term = searchTerm.toLowerCase().trim();
        let visibleCount = 0;
        
        searchPosts.forEach(post => {
          const element = post.element;
          if (!element) return;
          
          // 移除之前的高亮
          removeHighlight(element);
          
          if (!term) {
            // 如果搜索词为空，显示所有文章
            element.style.display = 'block';
            visibleCount++;
            return;
          }
          
          // 检查标题、描述和标签是否匹配
          const titleMatch = post.title.toLowerCase().includes(term);
          const descMatch = post.description.toLowerCase().includes(term);
          const tagMatch = post.tags.some(tag => tag.toLowerCase().includes(term));
          
          if (titleMatch || descMatch || tagMatch) {
            element.style.display = 'block';
            visibleCount++;
            
            // 高亮匹配的文本
            const titleElement = element.querySelector('.post-title a');
            const descElement = element.querySelector('.post-description');
            const tagElements = element.querySelectorAll('.tag');
            
            if (titleMatch && titleElement) {
              titleElement.innerHTML = highlightText(post.title, term);
            }
            if (descMatch && descElement) {
              descElement.innerHTML = highlightText(post.description, term);
            }
            if (tagMatch) {
              tagElements.forEach((tagEl, index) => {
                if (post.tags[index] && post.tags[index].toLowerCase().includes(term)) {
                  tagEl.innerHTML = highlightText(post.tags[index], term);
                }
              });
            }
          } else {
            element.style.display = 'none';
          }
        });
        
        // 更新搜索统计
        if (searchStats) {
          if (term) {
            if (visibleCount === 0) {
              searchStats.textContent = '没有找到相关文章';
              if (noResults) noResults.style.display = 'block';
            } else {
              searchStats.textContent = `找到 ${visibleCount} 篇相关文章`;
              if (noResults) noResults.style.display = 'none';
            }
          } else {
            searchStats.textContent = `共 ${searchPosts.length} 篇文章`;
            if (noResults) noResults.style.display = 'none';
          }
        }
      }
      
      // 防抖函数
      function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
          const later = () => {
            clearTimeout(timeout);
            func(...args);
          };
          clearTimeout(timeout);
          timeout = setTimeout(later, wait);
        };
      }
      
      // 绑定搜索事件
      const debouncedSearch = debounce((e) => {
        const target = e.target;
        if (target) {
          performSearch(target.value);
        }
      }, 300);
      
      if (searchInput) {
        searchInput.addEventListener('input', debouncedSearch);
        
        // 支持回车键搜索
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            performSearch(searchInput.value);
          }
        });
        
        // 清空搜索时恢复所有文章
        searchInput.addEventListener('keyup', (e) => {
          const target = e.target;
          if (e.key === 'Escape' || (!target.value && e.key === 'Backspace')) {
            searchInput.value = '';
            performSearch('');
          }
        });
      }
      
      // 初始化显示统计
      if (searchStats) {
        searchStats.textContent = `共 ${searchPosts.length} 篇文章`;
      }
    </script>
  </body>
